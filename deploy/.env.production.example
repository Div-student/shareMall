# 复制为 deploy/.env.production 后修改（勿提交 Git）
# cp deploy/.env.production.example deploy/.env.production

# ---------- MySQL（docker-compose 内 mysql 服务）----------
MYSQL_ROOT_PASSWORD=请替换为强密码
MYSQL_DATABASE=sharemall

# ---------- NestJS 后端 ----------
PORT=3000
NODE_ENV=production

DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=请与_MYSQL_ROOT_PASSWORD_一致
DB_NAME=sharemall

REDIS_HOST=redis
REDIS_PORT=6379

# 生产环境务必替换为 32 位以上随机字符串
JWT_SECRET=请替换为随机密钥
JWT_EXPIRES_IN=7d

# 邀请码注册（可选，true 时注册必须带 inviteCode）
# INVITE_REQUIRED=false

# ---------- 短信（按需填写）----------
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
